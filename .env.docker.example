GO_CHAT_APP_PORT=8080

GO_PROXY=https://goproxy.cn,direct
ALPINE_REPO_HOST=mirrors.aliyun.com

SERVER_ADDR=:8080

MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=go_chat
MYSQL_USER=gochat
MYSQL_PASSWORD=change-me-db-password
MYSQL_DSN=gochat:change-me-db-password@tcp(mysql:3306)/go_chat?charset=utf8mb4&parseTime=True&loc=Local

REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET=change-me-jwt-secret
JWT_EXPIRE_HOURS=72

UPLOAD_DIR=/app/data/uploads
UPLOAD_MAX_IMAGE_MB=5
